# AgentMem environment configuration
# Copy this file to .env and fill in values before running docker compose up
#
#   cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────
# Inside Docker Compose the hostname is the service name ("postgres").
# For local development against a native Postgres, use "localhost".
DATABASE_URL=postgresql+asyncpg://agentmem:agentmem@postgres:5432/agentmem

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Embeddings ────────────────────────────────────────────────────────────
# "sentence-transformers" — self-hosted, no external API calls (recommended
#                           for regulated / air-gapped deployments).
#                           Requires: pip install agentmem[local]
#                           Model is downloaded from HuggingFace on first use
#                           (~1.3 GB). For fully offline use, pre-download and
#                           set SENTENCE_TRANSFORMER_MODEL to the local path.
# "voyage"                — Voyage AI finance-tuned model (best accuracy,
#                           requires VOYAGE_API_KEY, data leaves network)
# "openai"                — OpenAI text-embedding-3-small (dev fallback,
#                           requires OPENAI_API_KEY, data leaves network)
# "local"                 — deterministic hash-projection for unit tests only
EMBEDDING_PROVIDER=sentence-transformers
SENTENCE_TRANSFORMER_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIM=1024
VOYAGE_API_KEY=
OPENAI_API_KEY=

# ── Encryption ────────────────────────────────────────────────────────────
# AES-256-GCM master key — 32 random bytes, base64-encoded.
# Generate:
#   python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# Leave blank in dev to disable PII encryption; REQUIRED in production.
MASTER_ENCRYPTION_KEY=

# ── API authentication ────────────────────────────────────────────────────
# Seed used to sign API keys — change before any real data is ingested.
API_SECRET_SEED=dev-seed-change-in-production

# ── Admin ────────────────────────────────────────────────────────────────
# Separate admin secret (not an API key) protects /v1/admin/* endpoints.
# Used for provisioning API keys, managing information barriers, and
# configuring retention policies.  MUST be changed in production.
ADMIN_SECRET=dev-admin-secret-change-in-production

# ── LLM adjudication — Stage 3 supersession (optional) ───────────────────
# Catches paraphrase supersessions that rule-based Stage 2 misses.
# Costs ~$0.00025 per call (Claude Haiku); disabled by default.
ANTHROPIC_API_KEY=
LLM_ADJUDICATION_MODEL=claude-haiku-4-5-20251001
SUPERSESSION_LLM_STAGE=false

# ── Recall hot cache ─────────────────────────────────────────────────────
# Redis is required for the hot cache.  Set RECALL_CACHE_ENABLED=false to
# disable caching and always hit Postgres (useful for debugging).
RECALL_CACHE_ENABLED=true
RECALL_CACHE_TTL_SECONDS=60

# ── Supersession review ───────────────────────────────────────────────────
# Supersessions with confidence below this threshold appear in
# GET /v1/supersessions/review for human review.
SUPERSESSION_REVIEW_THRESHOLD=0.75

# ── Air-gapped mode ──────────────────────────────────────────────────────
# Set AIRGAP_MODE=true to guarantee that no customer data leaves the
# deployment boundary.  On startup, AgentMem will hard-fail if:
#   • EMBEDDING_PROVIDER is "voyage" or "openai" (external API calls)
#   • SUPERSESSION_LLM_STAGE is true (sends content to Anthropic)
#
# Recommended stack for air-gapped deployments:
#   AIRGAP_MODE=true
#   EMBEDDING_PROVIDER=sentence-transformers
#   SENTENCE_TRANSFORMER_MODEL=/opt/models/bge-large-en-v1.5  (pre-downloaded)
#   SUPERSESSION_LLM_STAGE=false
AIRGAP_MODE=false

# ── OpenTelemetry (optional) ──────────────────────────────────────────────
# Set OTEL_EXPORTER_OTLP_ENDPOINT to send traces to your observability
# platform (Grafana Tempo, Datadog, Honeycomb, etc.).
# Example: http://otel-collector:4317
# Leave blank to disable tracing (no OTel packages required unless set).
OTEL_SERVICE_NAME=agentmem
OTEL_EXPORTER_OTLP_ENDPOINT=
