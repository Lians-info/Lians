DATABASE_URL=postgresql+asyncpg://agentmem:agentmem@localhost:5432/agentmem
REDIS_URL=redis://localhost:6379/0

# "local" is deterministic and does not call external APIs.
EMBEDDING_PROVIDER=local
VOYAGE_API_KEY=
OPENAI_API_KEY=
EMBEDDING_DIM=1024

# Base64-encoded 32-byte key. Blank uses a dev-only deterministic key.
MASTER_ENCRYPTION_KEY=

API_SECRET_SEED=dev-seed-change-in-prod
LLM_ADJUDICATION_MODEL=gpt-4o-mini
SUPERSESSION_LLM_STAGE=false
